{
  "output": {
    "filePath": "flutter-template-code.xml",
    "style": "xml",
    "compress": true,
    "removeComments": false,
    "removeEmptyLines": true,
    "showLineNumbers": false,
    "copyToClipboard": false,
    "parsableStyle": false,
    "git": {
      "sortByChanges": true,
      "sortByChangesMaxCommits": 100
    },
    "headerText": "flutter-template — Base Docker development environment image for Flutter projects.\nGenerated by Repomix for AI-assisted code review and analysis."
  },
  "include": ["**/*", ".github/**/*"],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "flutter-template-code.xml",
      "repomix.config.json",
      "*.log",
      "*.lock"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
