# ── .env.example ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your project.
# The .env file is gitignored and must never be committed.
#
# Usage inside the container:
#   The Flutter app reads these via a package such as flutter_dotenv:
#     await dotenv.load(fileName: ".env");
#     final apiKey = dotenv.env['API_KEY'];
#
# Usage in CI:
#   Store secrets in GitHub → Settings → Secrets and variables → Actions.
#   Reference them in workflows as ${{ secrets.MY_SECRET }}.
# ─────────────────────────────────────────────────────────────────────────────

# App environment: development | staging | production
APP_ENV=development

# Example API key — replace with your actual service keys
API_KEY=your_api_key_here

# Example backend URL
API_BASE_URL=https://api.example.com

# Firebase (add after running: flutterfire configure)
# FIREBASE_PROJECT_ID=your-project-id
